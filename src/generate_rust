                        rs.write(f'    }}\n')
                        if is_conditional:
                            rs.write('    }\n')
                    else:
                        rs.write('    let mut %s: %s = %s;\n' % (f['name'], field_type, field_init) )
                        if is_conditional:
                            rs.write(f'    if {f['name']}_cond {{\n')
                        rs.write('      %s = %s;\n' % (f['name'], field_reader) )
