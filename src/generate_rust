                emit_SEEval_after = d['structures'][0][struct_name]['fields'][-1]['name']
            #print('%s: call_schema_eval=%s emit_SEEval_after=%s has_UserData=%s' % (struct_name, call_schema_eval, emit_SEEval_after, str(has_UserData)) )
            if 'FIXME' in d['structures'][0][struct_name]:
                rs.write(f'  dbg!("{struct_name} structure contains FIXME!");\n')
            if 'on_enter' in d['structures'][0][struct_name]:
                rs.write(f'  {d['structures'][0][struct_name]['on_enter']};\n')
            for f in d['structures'][0][struct_name]['fields']:
                #print(f'{struct_name}.{f['name']}')
                is_virtual_type_switch = 'eligible_type_ids' in f
                is_conditional = 'condition_rust' in f
                do_debug = debug_fields or ('debug' in f and f['debug'])
                if 'FIXME' in f:
                    rs.write(f'  dbg!("{struct_name}.{f['name']} field contains FIXME!");\n')
                if is_virtual_type_switch:
