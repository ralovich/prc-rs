            si = si + 1

def usage():
    print("Usage:")
    print("%s <input.json> output" % sys.argv[0])
    sys.exit(1)

if len(sys.argv) < 3:
    usage()

input_json = sys.argv[1]
output_module = sys.argv[2]
with open(input_json) as f, open(output_module, mode='w') as rs:
    d = json.load(f)
    codegen_rust(rs, d)

