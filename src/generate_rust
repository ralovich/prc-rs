                        if is_vbr_2param(f):
                            field_reader = field_type + f'::from_reader(rdr, {rust_condition_to_reader_condition(f['vbr'])}, {rust_condition_to_reader_condition(f['tol'])})?'
                    else:
                        field_type = f['data_type']
                        field_reader = field_type+'::from_reader(rdr, _ctx)?'
                        field_init = 'Default::default()'
                    if is_pointer:
                        field_type = f"Box<{field_type}>"
                        field_reader = f"Box::from({field_reader})"
                        field_init = f"Box::new({field_init})"
                    if is_conditional:
                    #    field_type = f"Option<{field_type}>"
                    #    #field_reader = f"Some({field_reader})"
                    #    field_init = f"None"
                        rs.write(f'  let {f['name']}_cond = {rust_condition_to_reader_condition(f['condition_rust'])};\n')
                    if is_vec:
                        rs.write('    let mut %s: Vec<%s> = Vec::with_capacity((%s) as usize);\n' % (f['name'], field_type, f['size']) )
