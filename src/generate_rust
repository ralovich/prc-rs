                            rs.write('      dbg!(&%s);\n' % f['name'] )
                        if 'expected_value' in f:
                            rs.write('      assert_eq!(%s, %s::try_from(%s.value).unwrap());\n' % (f['expected_value'][1], f['expected_value'][0], f['name']) )
                        if is_conditional:
                            rs.write('    }\n')
                if 'on_set' in f:
                    rs.write(f'    {f['on_set']};\n')
                if call_schema_eval and f['name'] == emit_SEEval_after:
                    rs.write('    let _ = _ctx.se.eval(rdr, %s as u32, false, 0);\n' % struct_name )
                    call_schema_eval = False
            if 'on_leave' in d['structures'][0][struct_name]:
                rs.write(f'  {d['structures'][0][struct_name]['on_leave']};\n')
            rs.write('    let rv = Self {\n')
            for f in d['structures'][0][struct_name]['fields']:
                is_virtual_type_switch = 'eligible_type_ids' in f
                is_conditional = 'condition_rust' in f
                if is_virtual_type_switch:
                    #rs.write('          // VSWITCH\n')
                    #rs.write('          %s_type_id,\n' % f['name'] )
                    #rs.write('          //let %s_tid: PRCType = PRCType::try_from(%s_type_id).unwrap();\n' % (f['name'], f['name']) )
                    rs.write('          %s_concrete,\n' % f['name'] )
                    continue
                #is_builtin = f['data_type'] in builtins
                #field_name = f['name'] if f['name'] != 'type' else 'type_'
                if is_conditional:
                    #rs.write(f'      {f['name']}: if {rust_condition_to_reader_condition(f['condition_rust'])} {{Some({f['name']})}} else {{None}},\n')
                    rs.write(f'    {f['name']}: if {f['name']}_cond {{Some({f['name']})}} else {{None}},\n')
                else:
                    rs.write( '      %s,\n' % f['name'])
            rs.write('''      };
    Ok(rv)
  }
  pub fn to_writer<W: BitWrite + ?Sized>(&self, _w: &mut W, _ctx: &mut PrcParsingContext) -> std::io::Result<()> {\n''')
            for f in d['structures'][0][struct_name]['fields']:
                is_virtual_type_switch = 'eligible_type_ids' in f
                if is_virtual_type_switch:
                    #rs.write('  // VSWITCH\n')
                    rs.write('  match &self.%s_concrete {\n' % f['name'] )
