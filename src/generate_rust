def rust_condition_to_reader_condition(cond):
    rcond = cond.replace("self.", "")
    #print('REPLACE: \"%s\" -> \"%s\"' % (cond, rcond))
    return rcond

def rust_condition_to_writer_condition(cond):
    rcond = cond.replace("self.", "")
    #print('REPLACE: \"%s\" -> \"%s\"' % (cond, rcond))
    return rcond

def is_vbr_1param(f):
    return 'vbr' in f and 'data_type' in f and f['data_type'] in vbr_1param

def is_vbr_2param(f):
    return 'vbr' in f and 'data_type' in f and f['data_type'] in vbr_2param

def codegen_rust(rs, d):

    print(d['version'])

    global builtins
    builtins = d['builtins']
    global vbr_1param
    vbr_1param = d['vbr_1param']
    global vbr_2param
    vbr_2param = d['vbr_2param']

    rs.write('''// -*- mode: rust; coding: utf-8-unix -*-
