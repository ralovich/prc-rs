                        rs.write('    %s_%sConcrete::%s(x) => &x.to_writer(_w, _ctx)?,\n' % (struct_name, f['name'], eti[1]) )
                    rs.write('''    %s_%sConcrete::Invalid(x) => panic!(
                "%s: Unrecognized subtype: {}!", x
            ),''' % (struct_name, f['name'], struct_name) )
                    rs.write('  };\n')
                else:
                    is_builtin = f['data_type'] in builtins
                    is_conditional = 'condition_rust' in f
                    is_pointer = 'is_pointer' in f
                    is_vec = 'is_vec' in f
                    is_mult = 'multiplicity' in f
                    if is_builtin:
                        field_type = f['data_type']
                        field_writer = 'to_writer(_w)?'
                        if is_vbr_1param(f):
                            field_writer = f'to_writer(_w, {rust_condition_to_reader_condition(f['vbr'])})?'
                        if is_vbr_2param(f):
                            field_writer = f'to_writer(_w, {rust_condition_to_reader_condition(f['vbr'])}, {rust_condition_to_reader_condition(f['tol'])})?'
                    else:
                        field_type = f['data_type']
                        field_writer = 'to_writer(_w, _ctx)?'
                    if is_conditional and (not is_vec and not is_mult):
                        #field_writer = f"as_ref().unwrap().{field_writer}"
                        rs.write(f'    let {f['name']}_cond = {rust_condition_to_writer_condition(f['condition_rust'])};\n')
                        rs.write(f'    let {f['name']} = self.{f['name']}.as_ref().unwrap();\n')
                    else:
                        rs.write(f'    let {f['name']} = self.{f['name']}.clone();\n')
                    if is_vec or is_mult:
                        if is_conditional:
                            rs.write('    if %s {\n' % rust_condition_to_writer_condition(f['condition_rust']) )
                            rs.write('    for i in self.%s.as_ref().unwrap() {\n' % f['name'])
                        else:
                            rs.write('    for i in &self.%s {\n' % f['name'])
                        rs.write('      i.%s;\n' % field_writer )
                        rs.write('    }\n')
                        if is_conditional:
                            rs.write('    }\n')
                    else:
                        if is_conditional:
                            #rs.write('    if %s {\n' % rust_condition_to_writer_condition(f['condition_rust']) )
                            rs.write(f'    if {f['name']}_cond {{\n')
                        rs.write('    %s.%s;\n' % (f['name'], field_writer) )
                        if is_conditional:
                            rs.write('    }\n')
            rs.write('''    Ok(())
  }

''')
            rs.write('}\n')

            #
